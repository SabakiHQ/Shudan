{
  "name": "@sabaki/shudan",
  "version": "2.0.0",
  "description": "A highly customizable, low-level Goban web component.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    },
    "./min": {
      "import": "./dist/min.js",
      "types": "./dist/main.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SabakiHQ/Shudan.git"
  },
  "keywords": [
    "go",
    "weiqi",
    "baduk",
    "goban",
    "boardgame",
    "ui",
    "component",
    "preact",
    "react"
  ],
  "author": "Yichuan Shen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SabakiHQ/Shudan/issues"
  },
  "homepage": "https://github.com/SabakiHQ/Shudan",
  "scripts": {
    "test-base": "npm run build && node --enable-source-maps --experimental-test-coverage --test",
    "test": "npm run test-base -- \"dist/**/*.test.js\"",
    "prepublishOnly": "npm run build",
    "build": "tsc && rspack build",
    "serve-demo": "rspack --config ./rspack.demo.config.js dev --watch",
    "build-demo": "rspack --config ./rspack.demo.config.js build"
  },
  "peerDependencies": {
    "sinho": "^0.3.7"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@rspack/cli": "^1.7.10",
    "@rspack/core": "^1.7.10",
    "@types/node": "^22.19.17",
    "typescript": "^6.0.2"
  }
}
